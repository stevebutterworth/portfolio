<% content_for :title, "Contact · Steve Butterworth" %>
<% content_for :description, "Get in touch about your next project, launch or data problem." %>

<div class="grid grid-cols-1 md:grid-cols-2">
  <div class="border-line px-5 py-12 md:border-r md:px-10 md:py-16">
    <span class="text-xs font-semibold uppercase tracking-widest text-accent-d">Contact</span>
    <h1 class="mt-3.5 text-4xl font-medium leading-tight tracking-tight md:text-[44px]">Let&rsquo;s build something.</h1>
    <p class="mt-4 max-w-[40ch] font-body text-base leading-relaxed text-ink2">Got a project, a launch with an immovable deadline, or a data mess that needs taming? Tell me a little about it and I&rsquo;ll get back to you.</p>

    <div class="mt-6 flex flex-col gap-4 border-t border-line pt-5">
      <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-widest text-avail">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-avail shadow-[0_0_0_3px_rgba(21,154,91,0.18)]"></span>Available for work
      </div>

      <div class="flex items-center gap-2.5 font-body text-sm text-ink2">
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-[#b3ada2]"><path d="M22 4H2v16h20V4zm-2 2v.5l-8 5-8-5V6h16zM4 18V8.3l8 5 8-5V18H4z"/></svg>
        <%= obfuscated_mail_to "stevebutterworth@me.com" %>
      </div>

      <div class="flex items-center gap-2.5 font-body text-sm text-ink2">
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-[#b3ada2]"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"/></svg>
        Ipswich, Suffolk
      </div>

      <div class="mt-1 flex gap-4">
        <a href="https://www.linkedin.com/in/stevebutterworth/" target="_blank" rel="noopener" title="LinkedIn" class="text-[#a7abb5] transition hover:text-accent">
          <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
        </a>
        <a href="https://github.com/stevebutterworth" target="_blank" rel="noopener" title="GitHub" class="text-[#a7abb5] transition hover:text-accent">
          <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.4-.5-1.6.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.8.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="px-5 py-12 md:px-10 md:py-16">
    <form action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="<%= @web3forms_access_key %>">
      <input type="hidden" name="subject" value="New message from stevebutterworth.co.uk">
      <input type="hidden" name="from_name" value="stevebutterworth.co.uk contact form">

      <div class="mb-4">
        <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-wide text-accent-d">Your name</label>
        <input type="text" name="name" required placeholder="Jane Smith"
               class="w-full rounded-lg border border-line bg-[#FAFAFB] px-3.5 py-3 font-body text-[15px] text-ink focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,79,214,0.14)] focus:outline-none">
      </div>

      <div class="mb-4">
        <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-wide text-accent-d">Email</label>
        <input type="email" name="email" required placeholder="jane@company.com"
               class="w-full rounded-lg border border-line bg-[#FAFAFB] px-3.5 py-3 font-body text-[15px] text-ink focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,79,214,0.14)] focus:outline-none">
      </div>

      <div class="mb-4">
        <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-wide text-accent-d">Message</label>
        <textarea name="message" required placeholder="What are you building?" rows="5"
                  class="w-full resize-y rounded-lg border border-line bg-[#FAFAFB] px-3.5 py-3 font-body text-[15px] text-ink focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,79,214,0.14)] focus:outline-none"></textarea>
      </div>

      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off">

      <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-xs font-semibold uppercase tracking-wide text-white">
        Send message &rarr;
      </button>
    </form>
  </div>
</div>
