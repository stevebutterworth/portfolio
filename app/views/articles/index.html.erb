<% content_for :title, "Writing · Steve Butterworth" %>
<% content_for :description, "Essays on Rails, data-heavy systems, and shipping software that has to run in the wild on the night." %>

<div class="border-b border-line px-5 pb-8 pt-12 md:px-10 md:pb-10 md:pt-16">
  <span class="font-mono text-xs uppercase tracking-widest text-coral-d">// Writing</span>
  <h1 class="mt-3.5 text-4xl font-medium leading-[1.06] tracking-tight md:text-[44px]">Notes from the build.</h1>
  <p class="mt-3 max-w-[56ch] font-body text-base leading-relaxed text-ink2">Essays on Rails, data-heavy systems, and shipping software that has to run in the wild on the night.</p>
</div>

<% @articles.each do |article| %>
  <%= link_to article_path(article.slug), class: "group grid grid-cols-1 gap-5 border-b border-line px-5 py-7 transition hover:bg-[#efe9dc] md:grid-cols-[220px_1fr] md:gap-6 md:px-10 md:py-8" do %>
    <div class="overflow-hidden rounded-lg">
      <% if article.thumbnail.present? %>
        <img src="<%= asset_media(article.thumbnail) %>" alt="<%= article.title %>"
             loading="lazy" class="aspect-[16/10] w-full object-cover">
      <% else %>
        <div class="flex aspect-[16/10] w-full items-center justify-center bg-[#efe9dc] font-mono text-2xl font-bold text-coral">//</div>
      <% end %>
    </div>
    <div>
      <div class="font-mono text-[11px] uppercase tracking-wide text-muted">
        <%= article.date.strftime("%-d %b %Y") %> &middot; <%= article.author %> &middot; <%= article.reading_time %> min read
      </div>
      <h3 class="mt-2 text-xl font-semibold tracking-tight md:text-2xl"><%= article.title %></h3>
      <p class="mt-2 max-w-[62ch] font-body text-sm leading-relaxed text-ink2"><%= article.excerpt %></p>
      <div class="mt-3 flex flex-wrap gap-2">
        <% article.tags.each do |tag| %>
          <span class="rounded border border-line px-2 py-0.5 font-mono text-[11px] text-ink2"><%= tag %></span>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
