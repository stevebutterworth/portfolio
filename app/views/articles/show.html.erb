<% content_for :title, "#{@article.title} · Steve Butterworth" %>
<% content_for :description, @article.excerpt %>
<% content_for :og_type, "article" %>
<% content_for :og_image, request.base_url + asset_media(@article.cover) if @article.cover.present? %>

<div class="mx-auto max-w-[760px] px-5 pb-20 pt-12 md:px-6 md:pt-16">
  <%= link_to articles_path, class: "text-[11px] font-semibold uppercase tracking-widest text-accent-d" do %>
    &larr; All writing
  <% end %>

  <h1 class="mt-4 text-4xl font-semibold leading-[1.08] tracking-tight md:text-[40px]"><%= @article.title %></h1>
  <p class="mt-3.5 font-body text-[17px] leading-relaxed text-ink2"><%= @article.excerpt %></p>

  <div class="my-5 flex items-center gap-3 border-y border-line py-3.5">
    <div class="h-[34px] w-[34px] shrink-0 rounded-full bg-[#cdd6ee]"></div>
    <div>
      <div class="text-sm font-semibold"><%= @article.author %></div>
      <div class="text-[11px] font-semibold uppercase tracking-wide text-muted">
        <%= @article.date.strftime("%-d %b %Y") %> &middot; <%= @article.reading_time %> min read
        <% if @article.tags.any? %>
          &middot; <%= @article.tags.join(", ") %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @article.cover.present? %>
    <img src="<%= asset_media(@article.cover) %>" alt="<%= @article.title %>" class="mb-6 w-full rounded-xl">
  <% end %>

  <div class="prose-post">
    <%= @article.body_html.html_safe %>
  </div>
</div>
