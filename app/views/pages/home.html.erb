<% content_for :title, "Steve Butterworth · Full-Stack Rails Engineer" %>
<% content_for :description, "Full-stack Rails engineer with over 20 years building, shipping and operating reliable web applications." %>

<section class="grid grid-cols-1 items-end border-b border-line md:grid-cols-2">
  <div class="px-5 pb-8 pt-12 md:px-10 md:pb-12 md:pt-16">
    <div class="text-[11px] font-semibold uppercase tracking-widest text-accent-d">Full-Stack Rails Engineer</div>
    <h1 class="mt-3.5 max-w-[22ch] text-4xl font-medium leading-[1.06] tracking-tight md:text-[50px] md:leading-[1.03]">I architect, build and operate reliable web applications.</h1>
  </div>
  <div class="px-5 pb-10 md:px-10 md:pb-12 md:pt-16">
    <p class="max-w-[46ch] font-body text-base leading-relaxed text-ink2">Over 20 years of whole-product ownership. Thirteen years as sole engineer on the UK&rsquo;s leading environmental jobs site, a bootstrapped AI monitoring SaaS used by Am Law 200 firms, and live event screens for The Open serving over a million visits a day.</p>
    <div class="mt-4 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-widest text-avail">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-avail shadow-[0_0_0_3px_rgba(21,154,91,0.18)]"></span>Available for work
    </div>
  </div>
</section>

<div class="flex items-baseline justify-between px-5 pb-1 pt-8 md:px-10">
  <span class="text-xs font-semibold uppercase tracking-widest text-accent-d">Selected work</span>
  <span class="text-xs font-semibold uppercase tracking-widest text-muted"><%= format("%02d", @projects.size) %> projects</span>
</div>

<% @projects.each_with_index do |project, index| %>
  <%= render "project", project: project, index: index %>
<% end %>

<section class="border-t border-line px-5 py-9 md:px-10 md:py-11">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-[330px_1fr]">
    <div>
      <span class="text-xs font-semibold uppercase tracking-widest text-accent-d">Other projects delivered for</span>
    </div>
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2 text-xs font-semibold uppercase tracking-widest text-ink2 md:justify-end md:pt-1">
      <% [ "Emirates Airlines", "British Airways", "St Modwen", "Lenovo", "Cambridge University Press" ].each do |name| %>
        <span><%= name %></span>
        <span class="last:hidden text-accent-d/50">/</span>
      <% end %>
    </div>
  </div>
</section>
