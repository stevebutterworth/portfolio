<%# alternate image side by index: even = image left, odd = image right %>
<article class="border-t border-line px-5 md:px-10">
  <div class="grid grid-cols-1 md:grid-cols-2">
    <div class="portfolio-cover-frame relative aspect-[4/3] overflow-hidden <%= index.odd? ? "md:order-2" : "" %>"
         <%= tag.attributes(data: { controller: "lightbox" }) if project.lightbox? %>>
      <img src="<%= asset_media(project.cover) %>" alt="<%= project.title %>"
           loading="<%= index.zero? ? "eager" : "lazy" %>"
           class="portfolio-cover h-full w-full object-cover <%= project.lightbox? ? "cursor-zoom-in" : "" %>"
           <%= tag.attributes(data: { lightbox_target: "cover", action: "click->lightbox#open" }) if project.lightbox? %>>
      <% if project.lightbox? %>
        <span class="absolute bottom-3.5 right-3.5 z-10 rounded-full bg-black/60 px-2.5 py-1.5 text-[11px] font-semibold uppercase tracking-wide text-white backdrop-blur">
          <%= project.gallery.size %> images<%= " · #{pluralize(project.videos.size, "video")}" if project.videos.any? %>
        </span>
        <template data-lightbox-target="data">
          <%= tag.div(nil, data: { images: ([project.cover] + project.gallery).to_json, videos: project.videos.to_json, title: project.title }) %>
        </template>
      <% end %>
    </div>
    <div class="flex flex-col justify-center py-8 md:px-10 md:py-11">
      <div class="text-[56px] font-bold leading-none tracking-tight text-[#dfe4f2]"><%= format("%02d", project.order) %></div>
      <h3 class="mb-3 mt-0.5 text-[29px] font-semibold tracking-tight"><%= project.title %></h3>
      <div class="prose-sm max-w-none text-[15px] leading-relaxed text-ink2"><%= project.body_html.html_safe %></div>
      <% if project.quote.present? %>
        <blockquote class="mt-5 border-l-2 border-accent pl-4 text-[15px] italic text-ink">
          &ldquo;<%= project.quote %>&rdquo;
          <div class="mt-2 text-[11px] font-semibold uppercase tracking-wide not-italic text-accent-d"><%= project.quote_author %></div>
        </blockquote>
      <% end %>
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <% project.tech.each do |t| %>
          <span class="rounded border border-line px-2 py-0.5 text-[11px] font-medium uppercase tracking-wide text-ink2"><%= t %></span>
        <% end %>
      </div>
      <% if project.credit.present? %>
        <div class="mt-2 text-[11px] text-muted"><%= project.credit %></div>
      <% end %>
    </div>
  </div>
</article>
